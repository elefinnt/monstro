{
  "name": "monstro",
  "version": "0.1.0",
  "private": true,
  "description": "Multiplayer Pokemon-Emerald-style 2D game (Phaser 3 + Colyseus)",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @monstro/server --filter @monstro/client dev",
    "dev:server": "pnpm --filter @monstro/server dev",
    "dev:client": "pnpm --filter @monstro/client dev",
    "build": "pnpm --filter @monstro/shared build && pnpm --filter @monstro/server build && pnpm --filter @monstro/client build",
    "typecheck": "pnpm -r typecheck",
    "generate:map": "node scripts/generate-map.mjs",
    "generate:lab": "node scripts/generate-lab.mjs",
    "smart-commit": "node scripts/local/smart-commit.mjs"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
