{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'No build step: the server runs TypeScript directly via tsx.'"
  },
  "deploy": {
    "startCommand": "pnpm --filter @monstro/server start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
